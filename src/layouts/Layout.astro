---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'JMT FPV League is shutting down for now after a server failure — with plans to return over the winter. Thanks to everyone who flew.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B0F14" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
      }
      body {
        background: #0b0f14;
      }
      @keyframes jmtPulse {
        0%,
        100% {
          opacity: 1;
          box-shadow: 0 0 8px rgba(245, 158, 11, 0.6);
        }
        50% {
          opacity: 0.45;
          box-shadow: 0 0 2px rgba(245, 158, 11, 0.2);
        }
      }
    </style>
  </body>
</html>
